# ─── Supabase (required for auth + sync) ─────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Dev Bypass ──────────────────────────────────────────────────────────────
# Set to "true" to skip auth entirely during development.
# Also available via: ?devbypass=true in the URL, or localStorage vt_dev_bypass=true
VITE_AUTH_BYPASS=true
